# Site URL
NEXT_PUBLIC_SITE_URL=https://www.globaltravelreport.com

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Unsplash API Key
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Cron Secret Key
CRON_SECRET_KEY=your_cron_secret_key_here

# Twitter API Keys
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_SECRET=your_twitter_access_secret_here

# Facebook API Keys
FACEBOOK_PAGE_ID=your_facebook_page_id_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# LinkedIn API Keys
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here

# Medium API Keys
MEDIUM_ACCESS_TOKEN=your_medium_access_token_here



# Saily.com Affiliate ID
SAILY_AFFILIATE_ID=your_saily_affiliate_id_here

# Nord VPN Affiliate ID
NORDVPN_AFFILIATE_ID=your_nordvpn_affiliate_id_here

# Enable affiliate tracking
NEXT_PUBLIC_ENABLE_AFFILIATE_TRACKING=true


# AI Provider Configuration
AI_PROVIDER=cloudflare

# Cloudflare Workers AI
CLOUDFLARE_AI_WORKER_URL=https://global-travel-report-ai.your-account.workers.dev
CLOUDFLARE_AI_WORKER_MODEL=@cf/meta/llama-3.2-3b-instruct
CLOUDFLARE_AI_WORKER_TOKEN=your_cloudflare_worker_token_here
