{
  "name": "global-travel-report",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "security-audit": "node scripts/security-audit.js",
    "security-audit:report": "node scripts/security-audit.js --report",
    "security-audit:verbose": "node scripts/security-audit.js --verbose",
    "security-check": "npm audit && npm run security-audit",
    "security-fix": "npm audit fix && npm run security-audit",
    "fix-http-urls": "node scripts/fix-http-urls.js",
    "fix-http-urls:dry": "node scripts/fix-http-urls.js --dry-run",
    "fix-http-urls:verbose": "node scripts/fix-http-urls.js --verbose",
    "analyze-bundle": "node scripts/analyze-bundle.js",
    "analyze-bundle:prod": "node scripts/analyze-bundle.js --production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check:images": "node scripts/check-images.js",
    "get-youtube-token": "node scripts/get-youtube-token.js",
    "get-tumblr-tokens": "node scripts/get-tumblr-tokens.js",
    "get-tumblr-tokens:with-verifier": "node scripts/get-tumblr-tokens.js --verifier=",
    "optimize-images": "node scripts/optimize-images.js",
    "convert-to-webp": "node scripts/convert-to-webp.js",
    "convert-to-webp:avif": "node scripts/convert-to-webp.js --avif",
    "generate-sw": "node scripts/generate-service-worker.js",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "postbuild": "next-sitemap",
    "content-audit": "node scripts/content-audit.js",
    "optimize-all": "npm run optimize-images && npm run convert-to-webp && npm run generate-sw && npm run generate-sitemap",
    "build:optimized": "npm run optimize-all && next build",
    "build:secure": "npm run security-check && npm run build:optimized",
    "verify:affiliates": "node scripts/verify-affiliates.js",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lighthouse https://globaltravelreport.com --chrome-flags='--headless' --output=json --output-path=./lighthouse-mobile.json",
    "lighthouse:desktop": "lighthouse https://globaltravelreport.com --chrome-flags='--headless' --preset=desktop --output=json --output-path=./lighthouse-desktop.json",
    "test:regression": "playwright test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:unit": "jest --testPathPatterns=\"__tests__/utils\"",
    "test:integration": "jest --testPathPatterns=\"__tests__/api\"",
    "test:components": "jest --testPathPatterns=\"__tests__/components\"",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:components && npm run test:e2e",
    "test:ci": "playwright install --with-deps && npm run test:all",
    "validate:social": "node scripts/validate-social-previews.js",
    "check:env": "node scripts/check-env-vars.js",
    "fetch:offers": "node scripts/fetch-affiliate-offers.js",
    "refresh:offers": "npm run fetch:offers",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:open": "cross-env ANALYZE=true next build && open .next/analyze/client.html",
    "analyze:server": "cross-env ANALYZE=true next build && open .next/analyze/server.html",
    "automation:health": "node -e \"fetch('https://www.globaltravelreport.com/api/cron/dailyAutoPublisher?health=1').then(r=>r.text()).then(console.log)\""
  },
  "dependencies": {
    "@extractus/feed-extractor": "7.1.6",
    "@google-analytics/data": "5.2.0",
    "@google/generative-ai": "0.24.1",
    "@hookform/resolvers": "5.0.1",
    "@radix-ui/react-compose-refs": "1.1.2",
    "@radix-ui/react-label": "2.1.4",
    "@radix-ui/react-popover": "1.1.11",
    "@radix-ui/react-radio-group": "1.3.4",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.0.3",
    "@radix-ui/react-slot": "1.0.2",
    "@radix-ui/react-tabs": "1.1.11",
    "@radix-ui/react-toast": "1.2.11",
    "@radix-ui/react-tooltip": "1.2.6",
    "@sentry/nextjs": "10.52.0",
    "@types/dompurify": "3.0.5",
    "@types/leaflet": "1.9.17",
    "@types/react-google-recaptcha": "2.1.9",
    "@types/uuid": "10.0.0",
    "axios": "1.16.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "3.3.1",
    "dompurify": "3.4.2",
    "framer-motion": "12.9.2",
    "google-gax": "5.0.3",
    "isomorphic-dompurify": "2.24.0",
    "js-yaml": "4.1.1",
    "leaflet": "1.9.4",
    "lucide-react": "0.523.0",
    "next": "16.2.6",
    "next-share": "0.27.0",
    "next-sitemap": "4.2.3",
    "next-themes": "0.4.6",
    "openai": "4.97.0",
    "react": "18.3.0",
    "react-dom": "18.3.0",
    "react-google-recaptcha": "3.1.0",
    "react-hook-form": "7.56.1",
    "react-icons": "5.5.0",
    "recharts": "2.15.3",
    "rss-parser": "3.13.0",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tailwindcss-animate": "1.0.7",
    "tumblr.js": "5.0.1",
    "twitter-api-v2": "1.22.0",
    "unsplash-js": "7.0.19",
    "uuid": "11.1.1",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@babel/plugin-syntax-jsx": "7.27.1",
    "@babel/preset-env": "7.27.2",
    "@babel/preset-react": "7.27.1",
    "@babel/preset-typescript": "7.27.1",
    "@next/bundle-analyzer": "16.2.6",
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.20",
    "@types/node": "24.0.4",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "19.1.15",
    "@types/react-dom": "19.1.9",
    "@types/xml2js": "0.4.14",
    "@typescript-eslint/eslint-plugin": "8.44.1",
    "@typescript-eslint/parser": "8.44.1",
    "autoprefixer": "10.4.19",
    "chalk": "^4.1.2",
    "critters": "0.0.23",
    "dotenv": "^16.4.5",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jest": "^28.0.0",
    "glob": "^10.3.10",
    "globby": "14.1.0",
    "gray-matter": "4.0.3",
    "imagemin": "7.0.1",
    "jest": "30.4.1",
    "jest-environment-jsdom": "30.4.1",
    "lint-staged": "^15.2.2",
    "node-fetch": "2.7.0",
    "null-loader": "4.0.1",
    "postcss": "8.5.14",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "sharp": "0.33.5",
    "tailwindcss": "3.4.1",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
